# CardPilot HQ - PROD environment example
APP_NAME=CardPilot HQ
APP_ENV=prod
PORT=3000

# Set your production domain(s)
# Example:
# CORS_ORIGIN=https://qa.cardpilot-hq.com,https://cardpilot-hq.com
CORS_ORIGIN=

AZURE_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_API_KEY=replace-with-prod-key
AZURE_MODEL_ID=prebuilt-read
AZURE_API_VERSION=2024-11-30
USE_MOCK_AI=false

# eBay OAuth
# Register your deployed callback URL in eBay developer console and use its RuName here.
EBAY_ENV=production
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_RUNAME=
FRONTEND_BASE_URL=https://cardpilot-hq.example.com
EBAY_OAUTH_SCOPES=https://api.ebay.com/oauth/api_scope,https://api.ebay.com/oauth/api_scope/sell.account,https://api.ebay.com/oauth/api_scope/sell.inventory,https://api.ebay.com/oauth/api_scope/sell.fulfillment,https://api.ebay.com/oauth/api_scope/sell.analytics.readonly
EBAY_ACCOUNT_DELETION_ENDPOINT=https://cardpilot-hq.example.com/compliance/ebay/marketplace-account-deletion
EBAY_ACCOUNT_DELETION_VERIFICATION_TOKEN=

# REQUIRED in production
BETA_ACCESS_TOKEN=replace-with-strong-secret

# Optional feedback -> GitHub backlog integration
FEEDBACK_GITHUB_TOKEN=
FEEDBACK_GITHUB_REPO=cardpilothq/cardpilothq.github.io
FEEDBACK_GITHUB_LABELS=enhancement,customer-feedback

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
AZURE_DAILY_LIMIT=0
AZURE_RETRY_ATTEMPTS=3
AZURE_SUBMIT_RETRY_ATTEMPTS=4
